# 前端建议优先通过内部 gateway / Supabase Edge Functions 访问 AI 与官方数据
VITE_GATEWAY_PROVIDER=auto     # client（本地兼容模式）| auto（有配置就自动走 gateway）| supabase
VITE_INTERNAL_API_BASE_URL=    # 可选：自定义 server gateway，如 https://api.example.com/internal
VITE_SUPABASE_URL=https://opxffcwacjucqyzfqgwo.supabase.co
VITE_SUPABASE_FUNCTIONS_URL=   # 可选：函数网关覆盖地址，默认取 ${VITE_SUPABASE_URL}/functions/v1
VITE_SUPABASE_ANON_KEY=sb_publishable_fzZZxoN6Dg6hxJy557ZHgQ_rBUL6gav
VITE_ENABLE_CLOUD_KNOWLEDGE=true  # 默认 true；配置 Supabase 后优先读云端知识库，否则自动回退到本地 seeded corpus
# 若已部署 official-source-fetch，结果页 / 疫情看板会自动显示「云端同步 / 内置兜底」状态

# 以下直连密钥仅用于本地开发/未部署 gateway 前的降级模式；生产建议迁到 Supabase secrets
VITE_AI_BASE_URL=            # AI API 地址，如 https://api.xiaomimimo.com
VITE_AI_MODEL=               # 模型名称，如 mimo-v2-flash
VITE_AI_API_KEY=             # AI API Key（生产尽量不要直接暴露给浏览器）
VITE_AMAP_KEY=               # 高德地图 Web 服务 Key
VITE_AMAP_JS_KEY=            # 高德地图 JS API Key（Web端）
VITE_AMAP_JS_SECURITY_KEY=   # 高德地图 JS API 安全密钥
VITE_AMAP_WEB_KEY=           # 高德地图 POI 搜索 Key
VITE_QWEATHER_KEY=           # 和风天气 API Key
VITE_QWEATHER_HOST=          # 和风天气 API Host（控制台→项目→设置，如 abc123.qweatherapi.com）
VITE_TAVILY_API_KEY=         # Tavily 联网搜索 Key（仅本地降级模式；生产建议改配到 official-source-fetch 的 TAVILY_API_KEY secret）
